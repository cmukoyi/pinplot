# Local Development Environment - DO NOT USE IN PRODUCTION
# Copy this to .env for local development only
# Safe defaults for local testing

# Database Configuration (Local)
POSTGRES_USER=ble_user
POSTGRES_PASSWORD=local_dev_password
POSTGRES_DB=ble_tracker

# MZone Client Secret
# Get actual credentials from PRODUCTION_CONFIG.md (not in repo)
# Option 1: Use production credentials to test with real data
MZONE_CLIENT_SECRET=your_mzone_client_secret_here

# Option 2: Leave empty to skip MZone integration locally
# MZONE_CLIENT_SECRET=
