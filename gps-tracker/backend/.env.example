# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_URL=postgresql://beacon_user:your-password-here@db:5432/beacon_telematics

# JWT Secret Key (generate a secure random string, min 32 chars)
SECRET_KEY=your-super-secret-jwt-key-min-32-chars-long

# SendGrid Email Configuration (Recommended for Production)
SENDGRID_API_KEY=your-sendgrid-api-key-here
FROM_EMAIL=noreply@beacontelematics.co.uk

# MZone API Configuration
MZONE_API_URL=https://api.myprofiler.com/oauth2/v1
MZONE_REDIRECT_URI=http://your-server-ip/api/v1/mzone/callback
MZONE_CLIENT_ID=Tracking_GPS
MZONE_CLIENT_SECRET=your-mzone-client-secret-here
MZONE_VEHICLE_GROUP_ID=8e4fe3a7-4d46-474d-bf57-993828f70968
# Trips group ID — may differ from vehicle group ID (check MZone portal)
MZONE_TRIPS_GROUP_ID=e7042dff-f0d8-42ec-9324-c4b730cf177d

# TrackSolid API Credentials
# TRACKSOLID_ACCOUNT — TrackSolid account username
# TRACKSOLID_PASSWORD — plaintext password (the code computes the MD5 before sending)
# TRACKSOLID_USER_ID — numeric user ID from TrackSolid portal
# TRACKSOLID_ORG_ID — organisation ID from TrackSolid portal
# TRACKSOLID_APP_KEY — Open-API app key (used by the standalone test script)
# TRACKSOLID_APP_SECRET — Open-API app secret (used by the standalone test script)
TRACKSOLID_ACCOUNT=your-tracksolid-account
TRACKSOLID_PASSWORD=your-tracksolid-password
TRACKSOLID_USER_ID=your-tracksolid-user-id
TRACKSOLID_ORG_ID=your-tracksolid-org-id
TRACKSOLID_APP_KEY=your-tracksolid-app-key
TRACKSOLID_APP_SECRET=your-tracksolid-app-secret

# Optional Settings
DEBUG=False

# Pinplot Indoor Tracking — shared secret between mqtt-bridge and backend
# Must match BRIDGE_API_KEY in docker-compose.yml / GitHub secrets
BRIDGE_API_KEY=bridge-key-change-me
