# Backend Environment Variables - LOCAL DEVELOPMENT ONLY
# Copy this file to backend/.env for local development
# These are SAFE defaults for local testing - DO NOT use in production

# ==================== Database ====================
DATABASE_URL=postgresql://ble_user:local_dev_password@db:5432/ble_tracker

# ==================== Security ====================
# JWT Secret Key (use simple key for local dev)
SECRET_KEY=local-development-secret-key-not-for-production-use-minimum-32-characters

# ==================== Email Configuration ====================
# Option 1: Use production SendGrid (if you want real emails locally)
# Get the actual key from PRODUCTION_CONFIG.md (not in repo)
SENDGRID_API_KEY=SG.YOUR_SENDGRID_API_KEY_HERE
FROM_EMAIL=noreply@pinplot.me

# Option 2: Skip email sending (emails will be logged to console instead)
# SENDGRID_API_KEY=
# FROM_EMAIL=dev@localhost

# ==================== MZone API Configuration ====================
# Use production credentials to test with real vehicle data
# Get actual values from PRODUCTION_CONFIG.md (not in repo)
MZONE_TOKEN_URL=https://login.mzoneweb.net/connect/token
MZONE_API_BASE=https://live.mzoneweb.net/mzone62.api
MZONE_CLIENT_ID=mz-scopeuk
MZONE_CLIENT_SECRET=your_mzone_client_secret_here
MZONE_USERNAME=your_mzone_username
MZONE_PASSWORD=your_mzone_password
MZONE_VEHICLE_GROUP_ID=your_vehicle_group_id_here

# ==================== MProfiler API (IMEI Validation) ====================
MPROFILER_API_KEY=Basic T0NJX1Njb3BlVUtfTVo6T0NJU2NvcGVVS01aMDEh

# ==================== Optional Settings ====================
DEBUG=True
ENVIRONMENT=development

# ==================== CORS Settings ====================
# Allow all origins for local development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:8000
